$(document).ready(function() {
    $('[data-tab]').on('click', function() {
        var tabId = $(this).data('tab');
        $('[data-tab-content]').hide();
        $('[data-tab-content="' + tabId + '"]').css({
            opacity: 0,
            transform: 'translateY(20px)',
            display: 'block'
        });
        setTimeout(() => {
            $('[data-tab-content="' + tabId + '"]').css({
                opacity: 1,
                transform: 'translateY(0)',
                transition: 'opacity 0.3s ease-out, transform 0.3s ease-out'
            });
        }, 50);
        $('[data-tab]').attr('data-active', 'false');
        $(this).attr('data-active', 'true');
    });
    if ($('[data-active="true"]').length === 0) {
        $('[data-tab]:first').attr('data-active', 'true');
        var firstTabId = $('[data-tab]:first').data('tab');
        $('[data-tab-content="' + firstTabId + '"]').css({
            opacity: 1,
            transform: 'translateY(0)',
            display: 'block'
        });
    }
});


$(document).ready(function() {
    $('[data-faq-select]').on('click', function() {
        var faqId = $(this).attr('data-faq-id'); 
        var content = $('[data-faq-content="' + faqId + '"]'); 
        var icon = $(this).find('svg'); 
        if (content.is(':visible')) {
            content.slideUp(200);
            icon.removeClass('rotate-180');
        } else {
            $('[data-faq-content]').slideUp(200);
            $('[data-faq-select] svg').removeClass('rotate-180');
            content.slideDown(200);
            icon.addClass('rotate-180');
        }
    });
});


$(document).ready(function() {
    $('#mobile-menu-button').on('click', function() {
        var menu = $('#mobile-menu');
        var icon = $(this).find('svg');

        menu.slideToggle(300);
        icon.toggleClass('rotate-180');
    });

    $(window).on('resize', function() {
        if ($(window).width() >= 768) {
            $('#mobile-menu').hide();
        }
    });
});


$(document).ready(function() {
    const $jsonInput = $('#all_item_ids');

    // Se o elemento não existir ou estiver vazio, sai da função
    if (!$jsonInput.length || !$jsonInput.val()) return;

    let jsonProducts;
    try {
        jsonProducts = JSON.parse($jsonInput.val());
    } catch (error) {
        console.error("Erro ao processar JSON:", error);
        return;
    }

    // Ordena os produtos pela quantidade crescente
    jsonProducts.sort((a, b) => a.quantity - b.quantity);

    const $quantityDisplay = $('#quantity');
    const $itemIds = $('#item_ids');
    const $priceDisplay = $('#price');
    const $discountDisplay = $('#discount');
    const $subprice = $('#subprice');
    const $discountprice = $('#discountprice');
    
    // Obtém o primeiro item sem desconto para referência do preço original
    const minPriceItem = jsonProducts.find(item => parseFloat(item.discount) === 0);
    const minPrice = minPriceItem ? parseFloat(minPriceItem.price) : null;

    // Obtém o ID do item inicial
    let initialItemId = $itemIds.val();
    let currentIndex = jsonProducts.findIndex(product => product.item_ids === initialItemId);

    if (currentIndex === -1) {
        currentIndex = 0;
        $itemIds.val(jsonProducts[0].item_ids);
    }

    function updateDisplay(index) {
        const selectedPackage = jsonProducts[index];
        if (!selectedPackage) return;

        const price = parseFloat(selectedPackage.price);
        const discountPercent = parseFloat(selectedPackage.discount);

        // Calcula o preço original com base no menor preço sem desconto
        let originalPrice = minPrice ? minPrice * (selectedPackage.quantity / minPriceItem.quantity) : price;
        let discountValue = originalPrice - price;

        $quantityDisplay.text(selectedPackage.quantity.toString().replace(/\B(?=(\d{3})+(?!\d))/g, "."));
        $itemIds.val(selectedPackage.item_ids);
        
        // Usa a nova função global para atualizar o preço junto com os upsells
        if (typeof window.updateTotalPrice === 'function') {
            window.updateTotalPrice({
                basePrice: price,
                baseOriginalPrice: originalPrice,
                baseDiscountValue: discountValue,
                baseQuantity: parseInt(selectedPackage.quantity, 10) || 0
            });
        } else {
            $priceDisplay.text(`R$ ${price.toFixed(2).replace('.', ',')}`);
        }
        
        $subprice.text(`R$ ${originalPrice.toFixed(2).replace('.', ',')}`);
        $discountprice.text(`-R$ ${discountValue.toFixed(2).replace('.', ',')}`);

        if (discountPercent > 0) {
            $discountDisplay.text(`${discountPercent}% de Desconto`);
        } else {
            $discountDisplay.text("Aumente a quantidade para desconto");
        }
    }

    updateDisplay(currentIndex);

    $('[data-quantity-step]').on('click', function() {
        const isIncrease = $(this).find('path').length > 1; // Verifica se é o botão de adicionar (tem dois <path> no SVG)

        if (isIncrease && currentIndex < jsonProducts.length - 1) {
            currentIndex++;
        } else if (!isIncrease && currentIndex > 0) {
            currentIndex--;
        }

        updateDisplay(currentIndex);
    });
});

class AlertMessage {
    constructor() {
        // Espera o DOM estar pronto antes de inicializar
        this.initializePromise = new Promise((resolve) => {
            if (document.readyState === 'complete' || document.readyState === 'interactive') {
                this.initializeViewport();
                resolve();
            } else {
                document.addEventListener('DOMContentLoaded', () => {
                    this.initializeViewport();
                    resolve();
                });
            }
        });
        
        this.autoDismissTime = 5000; // 5 segundos
        this.toastCount = 0;
        this.maxToasts = 3;
    }

    initializeViewport() {
        try {
            this.viewport = document.getElementById('toastViewport');
            
            if (!this.viewport) {
                this.viewport = document.createElement('div');
                this.viewport.id = 'toastViewport';
                this.viewport.className = 'toast-viewport';
                
                // Garante que o body existe antes de adicionar
                if (document.body) {
                    document.body.appendChild(this.viewport);
                } else {
                    // Fallback: adiciona quando o DOM estiver pronto
                    document.addEventListener('DOMContentLoaded', () => {
                        document.body.appendChild(this.viewport);
                    });
                }
            }
        } catch (error) {
            console.error('Erro ao inicializar toast viewport:', error);
        }
    }

    async show(message, status = 'info', options = {}) {
        // Espera a inicialização completar
        await this.initializePromise;
        
        if (!this.viewport) {
            console.error('Toast viewport não está disponível');
            return null;
        }

        // Limita o número de toasts
        if (this.toastCount >= this.maxToasts) {
            this.removeOldestToast();
        }

        const toast = document.createElement('div');
        toast.className = `toast ${status}`;
        toast.setAttribute('role', 'alert');
        toast.setAttribute('aria-live', 'assertive');
        
        // Conteúdo do toast
        toast.innerHTML = `
            <div class="toast-content">
                <div class="toast-title">${options.title || this.getDefaultTitle(status)}</div>
                <div class="toast-description">${message}</div>
            </div>
            ${options.dismissible !== false ? 
                '<button class="toast-close" aria-label="Fechar">&times;</button>' : ''}
        `;

        // Adiciona ao DOM
        this.viewport.appendChild(toast);
        this.toastCount++;

        // Configura o fechamento
        if (options.dismissible !== false) {
            const closeBtn = toast.querySelector('.toast-close');
            closeBtn.addEventListener('click', () => this.dismissToast(toast));
        }

        // Auto-dismiss se não for persistente
        if (!options.persistent) {
            const timeout = setTimeout(() => {
                this.dismissToast(toast);
            }, options.duration || this.autoDismissTime);
            
            toast.dataset.timeoutId = timeout;
        }

        return toast;
    }

    dismissToast(toast) {
        if (!toast) return;
        
        clearTimeout(toast.dataset.timeoutId);
        toast.style.animation = 'fadeOut 0.3s ease-out';
        
        toast.addEventListener('animationend', () => {
            toast.remove();
            this.toastCount--;
        }, { once: true });
    }

    removeOldestToast() {
        const toasts = this.viewport.querySelectorAll('.toast');
        if (toasts.length > 0) {
            this.dismissToast(toasts[0]);
        }
    }

    getDefaultTitle(status) {
        const titles = {
            success: 'Sucesso!',
            error: 'Erro!',
            warning: 'Aviso',
            info: 'Informação'
        };
        return titles[status] || titles.info;
    }
}

// Cria instância global de forma segura
if (typeof window !== 'undefined' && !window.alertMessage) {
    window.alertMessage = new AlertMessage();
}


