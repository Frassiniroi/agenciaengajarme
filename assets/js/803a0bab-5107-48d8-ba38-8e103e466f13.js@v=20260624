// Funções globais para abrir/fechar
function openModal(modalId) {
  $('#' + modalId).fadeIn(200);
  $('body').css('overflow', 'hidden');
}

function closeModal(modalId) {
  $('#' + modalId).fadeOut(200);
  $('body').css('overflow', 'auto');
}

// Eventos com delegação para elementos dinâmicos
$(document).on('click', '[data-modal-close]', function() {
  const modalId = $(this).closest('.modal').attr('id');
  closeModal(modalId);
});



$(document).ready(function () {
    // Função para obter o valor do cookie
    function getCookie(name) {
        var cookieArr = document.cookie.split(';');
        for (var i = 0; i < cookieArr.length; i++) {
            var cookiePair = cookieArr[i].split('=');
            var cookieName = cookiePair[0].trim();
            if (cookieName === name) {
                return decodeURIComponent(cookiePair[1]);
            }
        }
        return null;
    }

    $('.ActionDinamicForm').on('submit', function (e) {
        e.preventDefault();

        var $form = $(this);
        var $submitBtn = $form.find('button[type="submit"]');
        var formAction = $form.attr('action'); // Obtém a URL do action do formulário

        // Desabilita o botão de envio
        $submitBtn.prop('disabled', true);

        var token = getCookie('token');
        if (!token) {
            alert('Token não encontrado! Por favor, recarregue a página.');
            $submitBtn.prop('disabled', false);
            return false;
        }

        // Usa a URL do formulário (formAction) em vez do caminho fixo
        $.post(formAction, $form.serialize() + '&' + $.param({ token: token }))
            .done(function (response) {
                console.log("Resposta recebida do servidor:", response); // Para verificar o conteúdo da resposta

                // Verifique se a resposta é um JSON válido
                try {
                    var parsedResponse = JSON.parse(response); // Tenta parsear a resposta como JSON
                    if (parsedResponse.status === 'error') {
                        // Exibe mensagem de erro, caso o status seja 'error'
                        alertMessage.show(parsedResponse.message || 'Erro no processamento', 'error', {
                            title: 'Error',
                            duration: 3000
                        });
                    } else if (parsedResponse.status === 'success') {
                        // Se for sucesso, insere o HTML no .form-content
                        $('.form-content').html(parsedResponse.orders_html);
                    }
                } catch (e) {
                    // Caso não seja um JSON, assume que é HTML e insere diretamente
                    $('.form-content').html(response);
                }

                // Habilita novamente o botão de envio
                $submitBtn.prop('disabled', false);
            })
            .fail(function (xhr, status, error) {
                console.error('Erro no checkout:', {
                    httpStatus: xhr.status,
                    status: status,
                    error: error,
                    responseText: xhr.responseText
                });

                var message = 'Erro na comunicacao com o servidor';
                if (xhr.responseText && xhr.responseText.length < 300 && xhr.responseText.indexOf('<') === -1) {
                    message = xhr.responseText;
                } else if (xhr.status) {
                    message = 'Erro no servidor (HTTP ' + xhr.status + '). Verifique os logs do checkout.';
                }

                alertMessage.show(message, 'error', {
                    title: 'Falha no sistema',
                    duration: 5000
                });
                $submitBtn.prop('disabled', false);
            });
    });
});
